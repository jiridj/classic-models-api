# GitHub Container Registry Configuration
GITHUB_REPOSITORY=your-username/classic-models-api
API_VERSION=latest

# Django Configuration
DEBUG=0
SECRET_KEY=your-very-secure-secret-key-here-change-this
ALLOWED_HOSTS=192.168.1.8,localhost,127.0.0.1
# API Base URL for OpenAPI schema (defaults to http://localhost:8000)
# API_BASE_URL=https://qnap-jiri.myqnapcloud.com

# API Key Authentication (optional - for system-level access)
# If set, allows authentication via X-API-Key header with full admin access
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-api-key-here-change-this

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=classicmodels
MYSQL_USER=classicuser
MYSQL_PASSWORD=your-secure-mysql-password
